{%- liquid
  assign order = order | split: ','
  assign left = ''
  assign center = ''
  assign right = ''

  if first != blank
    assign left = 'first '
  endif

  for item in order
    assign column_key = item | append: '_position'
    assign row_key = item | append: '_row'
    assign item_row = settings[row_key] | default: 'top'
    assign item_column = settings[column_key] | default: 'left'

    case item
      when 'actions'
        assign item_column = 'right'
    endcase

    if item_row == row
      case item_column
        when 'left'
          assign left = left | append: item | append: ' '
        when 'center'
          assign center = center | append: item | append: ' '
        else
          assign right = right | append: item | append: ' '
      endcase
    endif
  endfor

  assign columns = 'left,center,right' | split: ','
-%}

{%- for column in columns -%}
  {%- capture items_for_column -%}
    {% case column %}
      {% when 'left' %}
        {{ left }}
      {% when 'center' %}
        {{ center }}
      {% else %}
        {{ right }}
    {% endcase %}
  {%- endcapture -%}

  {%- assign items_array = items_for_column | strip | split: ' ' | compact -%}

  {%- if items_array.size > 0 -%}
    <div
      class="header__column header__column--{{ column }}"
      data-testid="header-{{ row }}-{{ column }}"
    >
      {% for key in items_array %}
        {% unless key == blank %}
          {% case key %}
            {% when 'first' %}
              {{ first }}
            {% when 'logo' %}
              {{ logo }}
            {% when 'menu' %}
              {{ menu }}
            {% when 'localization' %}
              {{ localization }}
            {% when 'search' %}
                    {{ search }}
                    {% if settings.enable_wishlist or settings.enable_cart_icon %}
                      <span class="header-actions__post-search-inline">
                        {% if settings.enable_wishlist %}
                          <a
                            href="{{ settings.wishlist_link | default: '#' }}"
                            class="header-actions__action header-actions__wishlist"
                            aria-label="{{ settings.wishlist_label | default: 'Wishlist' }}"
                          >
                            {% if settings.wishlist_icon != blank %}
                              <img src="{{ settings.wishlist_icon | image_url: width: 32 }}" alt="{{ settings.wishlist_label | default: 'Wishlist' }}" class="header-actions__wishlist-img"/>
                            {% else %}
                              {% capture heart_svg %}{{ 'icon-heart.svg' | inline_asset_content }}{% endcapture %}
                              {% if heart_svg != blank %}
                                <span class="svg-wrapper" aria-hidden="true">{{ heart_svg }}</span>
                              {% else %}
                                <span class="header-actions__wishlist-fallback">
                                  ❤
                                </span>
                              {% endif %}
                            {% endif %}
                          </a>
                        {% endif %}

                        {% if settings.enable_cart_icon %}
                          <a
                            href="{{ routes.cart_url }}"
                            class="header-actions__action header-actions__cart-icon-link"
                            aria-label="Cart"
                          >
                            <span class="header-actions__cart-icon header-actions__cart-icon--static" aria-hidden="true">
                              <span class="svg-wrapper" aria-hidden="true">
                                {{ 'icon-cart.svg' | inline_asset_content }}
                              </span>
                              {% render 'cart-bubble', limit: 100, live_region: true, test_id: test_id %}
                            </span>
                          </a>
                        {% endif %}
                      </span>
                      {% assign rendered_search_icons = true %}
                    {% endif %}
            {% when 'mobile_search' %}
              {{ mobile_search }}
            {% when 'actions' %}
              {{ actions }}
              {% if rendered_search_icons == false %}
                <span class="header-actions__post-search-inline">
                  {% if settings.enable_wishlist %}
                    <a
                      href="{{ settings.wishlist_link | default: '#' }}"
                      class="header-actions__action header-actions__wishlist"
                      aria-label="{{ settings.wishlist_label | default: 'Wishlist' }}"
                    >
                      {% if settings.wishlist_icon != blank %}
                        <img src="{{ settings.wishlist_icon | image_url: width: 32 }}" alt="{{ settings.wishlist_label | default: 'Wishlist' }}" class="header-actions__wishlist-img"/>
                      {% else %}
                        {% capture heart_svg %}{{ 'icon-heart.svg' | inline_asset_content }}{% endcapture %}
                        {% if heart_svg != blank %}
                          <span class="svg-wrapper" aria-hidden="true">{{ heart_svg }}</span>
                        {% else %}
                          <span class="header-actions__wishlist-fallback">
                            {{ 'icon-heart.svg' | inline_asset_content }}
                          </span>
                        {% endif %}
                      {% endif %}
                    </a>
                  {% endif %}

                  {% if settings.enable_cart_icon %}
                    <a
                      href="{{ routes.cart_url }}"
                      class="header-actions__action header-actions__cart-icon-link"
                      aria-label="Cart"
                    >
                      <span class="header-actions__cart-icon header-actions__cart-icon--static" aria-hidden="true">
                        <span class="svg-wrapper" aria-hidden="true">
                          {{ 'icon-cart.svg' | inline_asset_content }}
                        </span>
                        {% render 'cart-bubble', limit: 100, live_region: true, test_id: test_id %}
                      </span>
                    </a>
                  {% endif %}
                </span>
                {% assign rendered_search_icons = true %}
              {% endif %}
            {% when 'app_blocks' %}
              {{ app_blocks }}
          {% endcase %}
        {% endunless %}
      {% endfor %}
    </div>
  {%- endif -%}
{%- endfor -%}
